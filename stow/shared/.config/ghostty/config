# NOTE:
# docs:
# ghostty +show-config --default --docs | nvim
# examples:
# https://github.com/search?q=path%3Aghostty%2Fconfig&type=code

# ghostty +list-fonts

font-size = 14

# monospace
# https://usgraphics.com/products/berkeley-mono
font-family = "Berkeley Mono Variable"
font-variation = wght=300
font-variation = wdth=100
font-family-bold = "Berkeley Mono Variable"
font-variation-bold = wght=800

# italics
# https://github.com/subframe7536/maple-font
font-family-italic = "Maple Mono"
font-variation-italic = wght=200
font-family-bold-italic = "Maple Mono"
font-variation-bold-italic = wght=800

window-title-font-family = "Berkeley Mono Variable"

macos-titlebar-style = tabs
macos-titlebar-proxy-icon = hidden
macos-option-as-alt = true

background-opacity = 0.96
background-blur-radius = 40

# ghostty +list-themes
# theme = dark:/Users/fredrik/.local/share/nvim-fredrik/lazy/tokyonight.nvim/extras/ghostty/tokyonight_moon,light:/Users/fredrik/.local/share/nvim-fredrik/lazy/nightfox.nvim/extra/dayfox/dayfox.ghostty
theme = dark:/Users/fredrik/.local/share/nvim-fredrik/site/pack/core/opt/zenbones.nvim/extras/ghostty/zenbones_dark,light:/Users/fredrik/.local/share/nvim-fredrik/site/pack/core/opt/zenbones.nvim/extras/ghostty/zenbones_light

# NOTE: workaround for https://github.com/ghostty-org/ghostty/discussions/12708
cursor-color = cell-foreground

mouse-hide-while-typing = true

# SSH integration: install ghostty's terminfo on remote hosts (ssh-terminfo),
# and fall back to TERM=xterm-256color if that fails (ssh-env). Fixes
# "can't find terminal definition for xterm-ghostty" warnings and garbled
# line editing on hosts that lack the xterm-ghostty terminfo entry.
shell-integration-features = ssh-env,ssh-terminfo

window-inherit-working-directory = false
tab-inherit-working-directory = false
working-directory = home

# keymaps
keybind = global:cmd+`=toggle_quick_terminal
keybind = shift+ctrl+left_bracket=previous_tab
keybind = shift+ctrl+right_bracket=next_tab
keybind = shift+ctrl+,=move_tab:-1
keybind = shift+ctrl+.=move_tab:+1

# splits:
# Cmd+Option+Arrow (←/→/↑/↓) - move focus in that direction
# Cmd+Ctrl+Arrow (←/→/↑/↓) - resize the split in that direction
keybind = cmd+ctrl+e=equalize_splits

# shader
# - https://github.com/hackr-sh/ghostty-shaders
# custom-shader = /Users/fredrik/code/public/ghostty-shaders/cursor_blaze.glsl
# custom-shader-animation = false
