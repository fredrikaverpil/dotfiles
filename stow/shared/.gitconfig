[user]
	name = Fredrik Averpil
	email = fredrik.averpil@gmail.com
	# for github only, fredrikaverpil@users.noreply.github.com
[core]
	excludesfile = ~/.gitignore_global
	# editor = code --wait  # vscode
	editor = nvim
[pull]
	ff = only
[merge]
	# tool = vscode
	# tool = neovim
	tool = diffview
[mergetool "vscode"]
	cmd = code --wait $MERGED
[mergetool "neovim"]
	cmd = nvim -d $LOCAL $REMOTE $BASE $MERGED
[mergetool "diffview"]
	cmd = "nvim -c 'DiffviewOpen'"
[mergetool]
	prompt = false
[diff]
	# tool = vscode
	# tool = neovim
	tool = nvim_difftool
	# tool = diffview
[difftool "vscode"]
	cmd = code --wait --diff $LOCAL $REMOTE
[difftool "neovim"]
	cmd = nvim -d $LOCAL $REMOTE
[difftool "nvim_difftool"]
	cmd = nvim -c \"packadd nvim.difftool\" -c \"DiffTool $LOCAL $REMOTE\"
[difftool "diffview"]
	cmd = "nvim -d '$LOCAL' '$REMOTE' -c 'DiffviewOpen'"
[difftool]
	prompt = false
[init]
	defaultBranch = main
[rebase]
	autostash = true
[commit]
	template = ~/.gitcommit
[push]
	autoSetupRemote = true

# Git commit signing
[include]
    path = ~/.gitconfig_1password

# GitHub https authentication
# Credential helpers are cumulative, not override: this host-scoped helper does
# NOT replace the generic `osxkeychain` helper inherited from the system
# gitconfig, it's appended after it — and osxkeychain, tried first, would answer
# with a cached (possibly stale) token. The empty `helper =` resets the list so
# gh is the sole credential source for github.com. Other hosts (e.g.
# codeberg.org) don't match this block and still use osxkeychain.
[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

# Always keep gitconfig for work at bottom of this file
[includeIf "gitdir:~/code/work/**/.git"]
	path = ~/.gitconfig_work

