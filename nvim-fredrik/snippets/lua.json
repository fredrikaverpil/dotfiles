{
  "notify": {
    "prefix": "noti",
    "body": "vim.notify(vim.inspect(${1:data}))",
    "description": "Snippet for vim.notify(vim.inspect(...))"
  },
  "lazyload": {
    "prefix": "laz",
    "body": "require(\"lazyload\").on_vim_enter(function() ${1:data} end)",
    "description": "Lazyload on VimEnter"
  }
}
