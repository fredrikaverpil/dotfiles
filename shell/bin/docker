#!/usr/bin/env bash
set -e

# Translate DOCKER_BACKEND → DOCKER_HOST before invoking the real docker CLI.
if [ -f "$HOME/.dotfiles/shell/lib/docker-backend.sh" ]; then
	# shellcheck source=/dev/null
	. "$HOME/.dotfiles/shell/lib/docker-backend.sh"
	docker_backend_apply
	docker_backend_status
fi

# Avoid recursing into this shim — strip its directory from PATH before exec.
SCRIPT_DIR_PATH=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
CLEAN_PATH=$(echo "$PATH" | awk -v RS=: -v ORS=: -v SCRIPT_PATH="$SCRIPT_DIR_PATH" '$0 != SCRIPT_PATH' | sed 's/:$//')
PATH="$CLEAN_PATH" command exec docker "$@"
